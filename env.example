APP_NAME=Strategy Showcase (Python)
HOST=0.0.0.0
PORT=8000
JWT_SECRET=replace-this-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=120

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=strategy_showcase_dev
# MySQL 连接池（可选）。长跑同步会长时间占连接；池过小或等待 _job_running 时仍占连接易导致其它接口超时、浏览器 Failed to fetch
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=40
# DB_POOL_TIMEOUT=120
# DB_POOL_RECYCLE=1800

STRATEGY_ROOT_DIR=D:/360云盘/指数部/策略研发与应用/展示策略
# 补充数据导入文件（后台「数据导入」），可为 .xlsx/.xls/.csv；不填则使用 STRATEGY_ROOT_DIR/数据/公司资料.xlsx
# SUPPLEMENT_COMPANY_EXCEL_PATH=D:/360云盘/指数部/策略研发与应用/展示策略/数据/公司资料.xlsx
# 周一至周五 17:00（分 时 日 月 星期；APScheduler：周一=0，0-4=工作日）
DAILY_JOB_CRON=0 17 * * 0-4

# 远程 Wind（SQL Server / WindDB）。不配也能启动；依赖行情的「更新/同步」需填写并连通。
# 本机需安装「ODBC Driver 17 for SQL Server」
#
# 方式一：主机与端口写在一行（与常见 DEFAULT_SOURCE_DB_CONFIG['server'] 一致）
# WIND_SQLSERVER_SERVER=111.229.130.90,16555
#
# 方式二：主机、端口分开
# WIND_SQLSERVER_SERVER=111.229.130.90
# WIND_SQLSERVER_PORT=16555
#
# WIND_SQLSERVER_DATABASE=winddb
# WIND_SQLSERVER_USER=hffund
# WIND_SQLSERVER_PASSWORD="your_password"
# 若密码含 # 号，必须用双引号包住整段密码，否则 # 会被当成注释
# WIND_SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server
# 若写成 {ODBC Driver 17 for SQL Server}，程序会自动去掉花括号

# —— 火山方舟（个股 AI 等）：Responses API，代码内已启用 tools web_search 以查最新公开信息 ——
# ARK_API_KEY=你的方舟_API_Key
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=ep-20260503233446-p4d2p

# —— 忘记密码邮件（可选）——
# 本程序只用到 SMTP 发信；POP3/IMAP 是给 Outlook 等收信用，不必填进本项目。
# 88.com 示例（SSL 端口 465）：
# SMTP_HOST=smtp.88.com
# SMTP_PORT=465
# SMTP_USE_SSL=true
# SMTP_USE_TLS=false
# SMTP_USER=完整邮箱地址
# SMTP_PASSWORD=邮箱密码或客户端专用密码
# SMTP_FROM_ADDR=与 SMTP_USER 一致的发件人地址
# 若改用 587 + STARTTLS：SMTP_PORT=587、SMTP_USE_SSL=false、SMTP_USE_TLS=true
# 网易 163（全开 SSL；本项目只需 SMTP）：smtp.163.com:465，SMTP_USE_SSL=true；SMTP_PASSWORD=客户端授权码
# 配置好后可由管理员调用 POST /api/admin/smtp-test 发送测试邮件（Bearer admin JWT）
# 「联系我们」站内信收件箱（仅服务端使用，前台不展示；默认 zh1111@88.com）
# CONTACT_US_INBOX_EMAIL=zh1111@88.com
# 对外访问站点根 URL（用于邮件内重置链接；不填则用当前请求的域名）
# PASSWORD_RESET_PUBLIC_BASE_URL=https://your-domain.com
# 仅开发/内网：在 forgot-password 接口 JSON 中直接返回重置链接（生产切勿开启）
# PASSWORD_RESET_RETURN_LINK_IN_JSON=false
