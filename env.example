APP_NAME=Strategy Showcase (Python)
HOST=0.0.0.0
PORT=8000
JWT_SECRET=replace-this-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Turso 应用主库（libSQL）
TURSO_DATABASE_URL=libsql://your-database-name-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token
# 本地嵌入式副本（同步到云端）；仅远程可设为空。Render 同区部署建议配置副本，减轻 Hrana「Stream already in use」
# TURSO_LOCAL_REPLICA=.turso/app.db

STRATEGY_ROOT_DIR=D:/360云盘/指数部/策略研发与应用/展示策略
# Render 部署：上传文件目录（与 Turso 同区导入）；留空则仅用本机 STRATEGY_ROOT_DIR 路径
# SERVER_UPLOAD_ROOT=./server-data
# SERVER_UPLOAD_MAX_MB=200
# Render 等同区导入：上传文件落盘目录（设此项后导入优先读服务器文件；本机开发可留空）
# SERVER_UPLOAD_ROOT=./server-data
# SERVER_UPLOAD_MAX_MB=200
# 补充数据导入文件（后台「数据导入」），可为 .xlsx/.xls/.csv；不填则使用 STRATEGY_ROOT_DIR/数据/公司资料.xlsx
# SUPPLEMENT_COMPANY_EXCEL_PATH=D:/360云盘/指数部/策略研发与应用/展示策略/数据/公司资料.xlsx
# 补充导入每批写入行数（远程 Turso 建议 100～300，过大可能单次请求超时）
# SUPPLEMENT_IMPORT_BATCH_SIZE=200
# 纯远程时实际每批行数上限（默认 50，避免单批远程写入过久页面像卡死）
# SUPPLEMENT_IMPORT_REMOTE_BATCH_SIZE=50
# RUNNING 超过该分钟数无 progress_at 更新则标 FAILED，可续传
# SUPPLEMENT_IMPORT_STALE_RUNNING_MINUTES=12
# Render 免费档：按策略串行拉 Wind 算净值/快照，避免多策略 EOD 同时驻留内存（默认 true）
# WIND_LOW_MEMORY_MODE=true
# 启动时若因日期迁移 OOM 导致 502 循环，可先设 true 让服务起来，再本地跑 scripts/normalize_turso_dates.py
# SKIP_STARTUP_DATE_NORMALIZATION=true
# 周一至周五 17:00 北京时间（分 时 日 月 星期；APScheduler：周一=0，0-4=工作日；调度器时区 Asia/Shanghai）
DAILY_JOB_CRON=0 17 * * 0-4

# Render 部署必填：TURSO_DATABASE_URL、TURSO_AUTH_TOKEN；Start Command 建议：
#   uvicorn app.main:app --host 0.0.0.0 --port $PORT
# Render 健康检查路径建议 /health/live（见 render.yaml）；详细状态用 GET /health?verbose=1
# Render 上勿设 TURSO_LOCAL_REPLICA（或仅用容器内英文路径）。Wind 在 Linux 无 ODBC 时连接失败不会阻止启动。

# 远程 Wind（SQL Server / WindDB）。不配也能启动；依赖行情的「更新/同步」需填写并连通。
# 本机 Windows：安装「ODBC Driver 17 for SQL Server」
# Render/Linux：须用仓库内 Dockerfile 部署（已装 msodbcsql17）；原生 Python 运行时无此驱动会报 file not found
# 云服务器防火墙须放行 Render 出口 IP 访问 SQL 端口（如 16555），与能否 ping 通无关
#
# 方式一：主机与端口写在一行（与常见 DEFAULT_SOURCE_DB_CONFIG['server'] 一致）
# WIND_SQLSERVER_SERVER=111.229.130.90,16555
#
# 方式二：主机、端口分开
# WIND_SQLSERVER_SERVER=111.229.130.90
# WIND_SQLSERVER_PORT=16555
#
# WIND_SQLSERVER_DATABASE=winddb
# WIND_SQLSERVER_USER=hffund
# WIND_SQLSERVER_PASSWORD="your_password"
# 若密码含 # 号，必须用双引号包住整段密码，否则 # 会被当成注释
# WIND_SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server
# 若写成 {ODBC Driver 17 for SQL Server}，程序会自动去掉花括号

# —— 火山方舟（个股 AI 等）：Responses API，代码内已启用 tools web_search 以查最新公开信息 ——
# ARK_API_KEY=你的方舟_API_Key
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=ep-20260503233446-p4d2p

# —— 忘记密码邮件（可选）——
# 本程序只用到 SMTP 发信；POP3/IMAP 是给 Outlook 等收信用，不必填进本项目。
# 88.com 示例（SSL 端口 465）：
# SMTP_HOST=smtp.88.com
# SMTP_PORT=465
# SMTP_USE_SSL=true
# SMTP_USE_TLS=false
# SMTP_USER=完整邮箱地址
# SMTP_PASSWORD=邮箱密码或客户端专用密码
# SMTP_FROM_ADDR=与 SMTP_USER 一致的发件人地址
# 若改用 587 + STARTTLS：SMTP_PORT=587、SMTP_USE_SSL=false、SMTP_USE_TLS=true
# 网易 163（全开 SSL；本项目只需 SMTP）：smtp.163.com:465，SMTP_USE_SSL=true；SMTP_PASSWORD=客户端授权码
# 配置好后可由管理员调用 POST /api/admin/smtp-test 发送测试邮件（Bearer admin JWT）
# 「联系我们」站内信收件箱（仅服务端使用，前台不展示；默认 zh1111@88.com）
# CONTACT_US_INBOX_EMAIL=zh1111@88.com
# 对外访问站点根 URL（用于邮件内重置链接；不填则用当前请求的域名）
# PASSWORD_RESET_PUBLIC_BASE_URL=https://your-domain.com
# 仅开发/内网：在 forgot-password 接口 JSON 中直接返回重置链接（生产切勿开启）
# PASSWORD_RESET_RETURN_LINK_IN_JSON=false
